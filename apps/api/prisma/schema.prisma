generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  ADMIN
  SUPER_ADMIN
}

enum RecordStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum Shift {
  MORNING
  AFTERNOON
  EVENING
  FULL_TIME
}

model User {
  id                      String                    @id @default(cuid()) @db.Uuid
  email                   String                    @unique
  phone                   String?
  avatar                  String?
  passwordHash            String?                   @map("password_hash")
  role                    Role                      @default(STUDENT)
  studentStatus           String                    @default("lead") @map("student_status")
  createdAt               DateTime                  @default(now())
  firstName               String
  lastName                String
  updatedAt               DateTime                  @updatedAt
  reviews                 Review[]
  preferences             UserPreferences?
  adminProfiles           UserAdminProfile[]
  enrollments             Enrollment[]
  enrollmentMessages      EnrollmentMessage[]
  enrollmentStatusChanges EnrollmentStatusHistory[]
  accommodationStatusChanges EnrollmentAccommodationStatusHistory[]
  enrollmentMessageReads  EnrollmentMessageRead[]
  notifications           Notification[]
  orders                  Order[]

  @@map("users")
}

model Enrollment {
  id                 String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  studentId          String                    @map("student_id") @db.Uuid
  institutionId      String                    @map("institution_id") @db.Uuid
  schoolId           String                    @map("school_id") @db.Uuid
  unitId             String                    @map("unit_id") @db.Uuid
  courseId           String                    @map("course_id") @db.Uuid
  classGroupId       String                    @map("class_group_id") @db.Uuid
  academicPeriodId   String                    @map("academic_period_id") @db.Uuid
  accommodationId    String?                   @map("accommodation_id") @db.Uuid
  accommodationOrderId String?                 @map("accommodation_order_id") @db.Uuid
  status             String                    @default("active")
  accommodationStatus String                   @default("not_selected") @map("accommodation_status")
  accommodationClosedAt DateTime?              @map("accommodation_closed_at")
  createdAt          DateTime                  @default(now()) @map("created_at")
  student            User                      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  institution        Institution               @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  school             School                    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  unit               Unit                      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  course             Course                    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  classGroup         ClassGroup                @relation(fields: [classGroupId], references: [id], onDelete: Cascade)
  academicPeriod     AcademicPeriod            @relation(fields: [academicPeriodId], references: [id], onDelete: Cascade)
  accommodation      Accommodation?            @relation(fields: [accommodationId], references: [id], onDelete: SetNull)
  accommodationOrder Order?                    @relation("EnrollmentAccommodationOrder", fields: [accommodationOrderId], references: [id], onDelete: SetNull)
  documents          EnrollmentDocument[]
  messages           EnrollmentMessage[]
  pricing            EnrollmentPricing?
  statusHistory      EnrollmentStatusHistory[]
  accommodationStatusHistory EnrollmentAccommodationStatusHistory[]
  messageReads       EnrollmentMessageRead[]
  payments           Payment[]
  invoices           Invoice[]
  quotes             EnrollmentQuote[]
  orders             Order[]                   @relation("EnrollmentOrders")

  @@index([studentId, status])
  @@index([institutionId])
  @@index([schoolId])
  @@index([unitId])
  @@index([courseId])
  @@index([classGroupId])
  @@index([academicPeriodId])
  @@index([accommodationId])
  @@index([accommodationOrderId])
  @@map("enrollment")
}

model Institution {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String       @unique @db.VarChar(255)
  description String?
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  schools     School[]
  enrollments Enrollment[]

  @@map("institution")
}

model Unit {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId    String       @map("school_id") @db.Uuid
  name        String       @db.VarChar(255)
  code        String       @db.VarChar(80)
  address     String?
  city        String?      @db.VarChar(120)
  state       String?      @db.VarChar(120)
  country     String?      @db.VarChar(120)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  school      School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  courses     Course[]
  enrollments Enrollment[]

  @@unique([schoolId, code])
  @@index([schoolId])
  @@map("unit")
}

model AcademicPeriod {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  classGroupId      String             @map("class_group_id") @db.Uuid
  name              String             @db.VarChar(150)
  startDate         DateTime           @map("start_date")
  endDate           DateTime           @map("end_date")
  status            RecordStatus       @default(ACTIVE)
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  classGroup        ClassGroup         @relation(fields: [classGroupId], references: [id], onDelete: Cascade)
  enrollments       Enrollment[]
  coursePricings    CoursePricing[]

  @@index([classGroupId])
  @@index([startDate, endDate])
  @@map("academic_period")
}

model ClassGroup {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId          String             @map("course_id") @db.Uuid
  name              String             @db.VarChar(255)
  code              String             @db.VarChar(80)
  shift             Shift
  status            RecordStatus       @default(ACTIVE)
  capacity          Int?
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  course            Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  periods           AcademicPeriod[]
  enrollments       Enrollment[]

  @@unique([courseId, code])
  @@index([courseId])
  @@map("class_group")
}

model Permission {
  id          String                   @id @default(cuid())
  key         String                   @unique
  description String
  createdAt   DateTime                 @default(now())
  profiles    AdminProfilePermission[]

  @@map("permission")
}

model AdminProfile {
  id          String                   @id @default(cuid())
  name        String                   @unique
  label       String
  description String?
  isSystem    Boolean                  @default(false)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  permissions AdminProfilePermission[]
  users       UserAdminProfile[]

  @@map("admin_profile")
}

model AdminProfilePermission {
  profileId    String
  permissionId String
  profile      AdminProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  permission   Permission   @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([profileId, permissionId])
  @@map("admin_profile_permission")
}

model UserAdminProfile {
  userId     String       @db.Uuid
  profileId  String
  assignedAt DateTime     @default(now())
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile    AdminProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@id([userId, profileId])
  @@map("user_admin_profile")
}

model UserPreferences {
  id                          String    @id @default(cuid())
  userId                      String    @unique @db.Uuid
  destinationCity             String
  destinationCountry          String
  budgetAccommodationMin      Int?
  budgetAccommodationMax      Int?
  budgetCourseMin             Int?
  budgetCourseMax             Int?
  purpose                     String
  englishLevel                String?
  arrivalDate                 DateTime?
  preferredAccommodationTypes String[]  @default([])
  interestedInAccommodation   Boolean?  @default(true) @map("interested_in_accommodation")
  accommodationTypePreference String?   @map("accommodation_type_preference") @db.VarChar(80)
  budgetPreference            String?   @map("budget_preference") @db.VarChar(80)
  locationPreference          String?   @map("location_preference") @db.VarChar(120)
  notes                       String?
  maxDistanceToSchool         Int?
  hasUnreadNotifications      Boolean   @default(false)
  notificationCount           Int       @default(0)
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt
  user                        User      @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "user_preferences_users_fk")

  @@index([destinationCity])
  @@index([destinationCountry])
  @@index([budgetAccommodationMax])
  @@index([englishLevel])
  @@map("user_preferences")
}

model Course {
  id                String             @id(map: "Course_pkey") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  unitId            String             @map("unit_id") @db.Uuid
  school_id         String             @db.Uuid
  program_name      String             @db.VarChar(255)
  weekly_hours      Int
  price_in_cents    Int?
  description       String
  duration          String             @db.VarChar(100)
  visa_type         String             @db.VarChar(100)
  target_audience   String
  image             String             @db.VarChar(500)
  images            String[]           @default([])
  badges            String[]
  rating            Decimal?           @default(0.00) @db.Decimal(3, 2)
  rating_count      Int?               @default(0)
  is_active         Boolean            @default(true)
  created_at        DateTime           @default(now())
  updated_at        DateTime           @default(now())
  price_unit        String?            @db.VarChar(20)
  period_type       String             @default("fixed") @db.VarChar(20)
  auto_approve_intent Boolean          @default(false)
  unit              Unit               @relation(fields: [unitId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  school            School             @relation(fields: [school_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "course_school_fk")
  classes           ClassGroup[]
  enrollments       Enrollment[]
  coursePricings    CoursePricing[]
  orderItems        OrderItem[]

  @@index([unitId])
  @@map("course")
}

model Review {
  id             String   @id(map: "Review_pkey") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @db.Uuid
  reviewableType String
  reviewableId   String   @db.Uuid
  rating         Int
  comment        String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now())
  user           User     @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "review_users_fk")

  @@map("review")
}

model School {
  id                           String                              @id(map: "School_pkey") @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  institutionId                String                              @map("institution_id") @db.Uuid
  name                         String                              @db.VarChar(255)
  location                     String                              @db.VarChar(255)
  description                  String?
  website                      String?                             @db.VarChar(500)
  phone                        String?                             @db.VarChar(50)
  email                        String?                             @db.VarChar(255)
  logo                         String?                             @db.VarChar(500)
  isPartner                    Boolean                             @default(false)
  createdAt                    DateTime                            @default(now())
  updatedAt                    DateTime                            @default(now())
  rating                       Decimal?                            @db.Decimal
  rating_count                 Int?
  badges                       String[]
  institution                  Institution                         @relation(fields: [institutionId], references: [id], onDelete: Cascade)
  units                        Unit[]
  course                       Course[]
  enrollments                  Enrollment[]
  accommodationRecommendations SchoolAccommodationRecommendation[]

  @@index([institutionId])
  @@map("school")
}

model Accommodation {
  id                    String                              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                 String                              @db.VarChar(255)
  accommodationType     String                              @map("accommodation_type") @db.VarChar(50)
  priceInCents          Int                                 @map("price_in_cents")
  priceUnit             String                              @default("month") @map("price_unit") @db.VarChar(20)
  location              String                              @db.VarChar(255)
  areaHint              String?                             @map("area_hint") @db.VarChar(255)
  latitude              Decimal?                            @db.Decimal(10, 8)
  longitude             Decimal?                            @db.Decimal(11, 8)
  description           String
  rules                 String[]                            @default([])
  amenities             String[]                            @default([])
  image                 String                              @db.VarChar(500)
  images                String[]                            @default([])
  rating                Decimal?                            @default(0.00) @db.Decimal(3, 2)
  ratingCount           Int?                                @default(0) @map("rating_count")
  ratingCleanliness     Decimal?                            @default(0.00) @map("rating_cleanliness") @db.Decimal(3, 2)
  ratingLocation        Decimal?                            @default(0.00) @map("rating_location") @db.Decimal(3, 2)
  ratingCommunication   Decimal?                            @default(0.00) @map("rating_communication") @db.Decimal(3, 2)
  ratingValue           Decimal?                            @default(0.00) @map("rating_value") @db.Decimal(3, 2)
  score                 Decimal?                            @default(0.00) @db.Decimal(5, 2)
  badges                String[]
  isPartner             Boolean?                            @default(false) @map("is_partner")
  isTopTrip             Boolean?                            @default(false) @map("is_top_trip")
  hostName              String?                             @map("host_name") @db.VarChar(255)
  hostAvatar            String?                             @map("host_avatar") @db.VarChar(500)
  isActive              Boolean?                            @default(true) @map("is_active")
  createdAt             DateTime?                           @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt             DateTime?                           @default(now()) @map("updated_at") @db.Timestamp(6)
  schoolRecommendations SchoolAccommodationRecommendation[]
  enrollments           Enrollment[]
  accommodationPricings AccommodationPricing[]
  orderItems            OrderItem[]

  @@map("accommodation")
}

model SchoolAccommodationRecommendation {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  schoolId        String        @map("school_id") @db.Uuid
  accommodationId String        @map("accommodation_id") @db.Uuid
  isRecommended   Boolean       @default(true) @map("is_recommended")
  priority        Int           @default(0)
  badgeLabel      String?       @map("badge_label") @db.VarChar(80)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  school          School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  accommodation   Accommodation @relation(fields: [accommodationId], references: [id], onDelete: Cascade)

  @@unique([schoolId, accommodationId])
  @@index([schoolId, isRecommended, priority])
  @@index([accommodationId])
  @@map("school_accommodation_recommendation")
}

model Place {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String    @db.VarChar(255)
  category          String    @db.VarChar(50)
  image             String
  images            String[]  @default([])
  rating            Decimal?  @default(0) @db.Decimal(2, 1)
  ratingCount       Int?      @default(0) @map("rating_count")
  address           String
  location          String?   @db.VarChar(100)
  latitude          Decimal?  @db.Decimal(10, 8)
  longitude         Decimal?  @db.Decimal(11, 8)
  isStudentFavorite Boolean?  @default(false) @map("is_student_favorite")
  hasDeal           Boolean?  @default(false) @map("has_deal")
  dealDescription   String?   @map("deal_description")
  priceRange        String?   @map("price_range") @db.VarChar(10)
  description       String?
  hours             Json?
  phone             String?   @db.VarChar(50)
  website           String?
  amenities         String[]  @default([])
  isActive          Boolean?  @default(true) @map("is_active")
  createdAt         DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)
  badges            String[]

  @@map("place")
}

model EnrollmentDocument {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enrollmentId String     @map("enrollment_id") @db.Uuid
  type         String     @db.VarChar(100)
  fileUrl      String     @map("file_url")
  status       String     @default("pending")
  adminNote    String?    @map("admin_note")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([enrollmentId, status])
  @@map("enrollment_document")
}

model EnrollmentMessage {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enrollmentId String     @map("enrollment_id") @db.Uuid
  senderId     String     @map("sender_id") @db.Uuid
  channel      String     @default("enrollment") @db.VarChar(40)
  message      String
  createdAt    DateTime   @default(now()) @map("created_at")
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  sender       User       @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([enrollmentId, channel, createdAt])
  @@index([senderId])
  @@map("enrollment_message")
}

model EnrollmentMessageRead {
  enrollmentId String     @map("enrollment_id") @db.Uuid
  userId       String     @map("user_id") @db.Uuid
  lastReadAt   DateTime   @default(now()) @map("last_read_at")
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([enrollmentId, userId])
  @@index([userId, lastReadAt])
  @@map("enrollment_message_read")
}

model EnrollmentPricing {
  id                                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enrollmentId                      String     @unique @map("enrollment_id") @db.Uuid
  basePrice                         Decimal    @map("base_price") @db.Decimal(12, 2)
  fees                              Decimal    @default(0) @db.Decimal(12, 2)
  discounts                         Decimal    @default(0) @db.Decimal(12, 2)
  totalAmount                       Decimal    @map("total_amount") @db.Decimal(12, 2)
  enrollmentAmount                  Decimal    @default(0) @map("enrollment_amount") @db.Decimal(12, 2)
  accommodationAmount               Decimal    @default(0) @map("accommodation_amount") @db.Decimal(12, 2)
  packageTotalAmount                Decimal    @default(0) @map("package_total_amount") @db.Decimal(12, 2)
  currency                          String     @default("CAD") @db.VarChar(10)
  commissionAmount                  Decimal    @default(0) @map("commission_amount") @db.Decimal(12, 2)
  commissionPercentage              Decimal    @default(0) @map("commission_percentage") @db.Decimal(7, 4)
  enrollmentCommissionAmount        Decimal    @default(0) @map("enrollment_commission_amount") @db.Decimal(12, 2)
  enrollmentCommissionPercentage    Decimal    @default(0) @map("enrollment_commission_percentage") @db.Decimal(7, 4)
  accommodationCommissionAmount     Decimal    @default(0) @map("accommodation_commission_amount") @db.Decimal(12, 2)
  accommodationCommissionPercentage Decimal    @default(0) @map("accommodation_commission_percentage") @db.Decimal(7, 4)
  totalCommissionAmount             Decimal    @default(0) @map("total_commission_amount") @db.Decimal(12, 2)
  createdAt                         DateTime   @default(now()) @map("created_at")
  updatedAt                         DateTime   @updatedAt @map("updated_at")
  enrollment                        Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@map("enrollment_pricing")
}

model CoursePricing {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  courseId         String         @map("course_id") @db.Uuid
  academicPeriodId String         @map("academic_period_id") @db.Uuid
  duration         String?        @db.VarChar(80)
  basePrice        Decimal        @map("base_price") @db.Decimal(12, 2)
  currency         String         @default("CAD") @db.VarChar(10)
  isActive         Boolean        @default(true) @map("is_active")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  course           Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  academicPeriod   AcademicPeriod @relation(fields: [academicPeriodId], references: [id], onDelete: Cascade)
  quotes           EnrollmentQuote[]
  quoteItems       EnrollmentQuoteItem[]

  @@unique([courseId, academicPeriodId])
  @@index([academicPeriodId])
  @@index([isActive])
  @@map("course_pricing")
}

model AccommodationPricing {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accommodationId String         @map("accommodation_id") @db.Uuid
  periodOption    String         @map("period_option") @db.VarChar(120)
  basePrice       Decimal        @map("base_price") @db.Decimal(12, 2)
  currency        String         @default("CAD") @db.VarChar(10)
  isActive        Boolean        @default(true) @map("is_active")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  accommodation   Accommodation  @relation(fields: [accommodationId], references: [id], onDelete: Cascade)
  quotes          EnrollmentQuote[]
  quoteItems      EnrollmentQuoteItem[]

  @@unique([accommodationId, periodOption])
  @@index([isActive])
  @@map("accommodation_pricing")
}

model EnrollmentQuote {
  id                          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enrollmentId                String?              @map("enrollment_id") @db.Uuid
  coursePricingId             String?              @map("course_pricing_id") @db.Uuid
  accommodationPricingId      String?              @map("accommodation_pricing_id") @db.Uuid
  courseAmount                Decimal              @default(0) @map("course_amount") @db.Decimal(12, 2)
  accommodationAmount         Decimal              @default(0) @map("accommodation_amount") @db.Decimal(12, 2)
  fees                        Decimal              @default(0) @db.Decimal(12, 2)
  discounts                   Decimal              @default(0) @db.Decimal(12, 2)
  totalAmount                 Decimal              @map("total_amount") @db.Decimal(12, 2)
  currency                    String               @default("CAD") @db.VarChar(10)
  downPaymentPercentage       Decimal              @default(30) @map("down_payment_percentage") @db.Decimal(7, 4)
  downPaymentAmount           Decimal              @map("down_payment_amount") @db.Decimal(12, 2)
  remainingAmount             Decimal              @map("remaining_amount") @db.Decimal(12, 2)
  commissionPercentage        Decimal              @default(0) @map("commission_percentage") @db.Decimal(7, 4)
  commissionAmount            Decimal              @default(0) @map("commission_amount") @db.Decimal(12, 2)
  commissionCourseAmount      Decimal              @default(0) @map("commission_course_amount") @db.Decimal(12, 2)
  commissionAccommodationAmount Decimal            @default(0) @map("commission_accommodation_amount") @db.Decimal(12, 2)
  type                        String               @db.VarChar(40)
  createdAt                   DateTime             @default(now()) @map("created_at")
  enrollment                  Enrollment?          @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  coursePricing               CoursePricing?       @relation(fields: [coursePricingId], references: [id], onDelete: SetNull)
  accommodationPricing        AccommodationPricing? @relation(fields: [accommodationPricingId], references: [id], onDelete: SetNull)
  items                       EnrollmentQuoteItem[]
  payments                    Payment[]
  invoices                    Invoice[]
  orders                      Order[]

  @@index([enrollmentId, createdAt])
  @@index([coursePricingId])
  @@index([accommodationPricingId])
  @@index([type])
  @@map("enrollment_quote")
}

model Payment {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enrollmentId      String?         @map("enrollment_id") @db.Uuid
  enrollmentQuoteId String?         @map("enrollment_quote_id") @db.Uuid
  invoiceId         String?         @map("invoice_id") @db.Uuid
  orderId           String?         @map("order_id") @db.Uuid
  type              String          @default("down_payment") @db.VarChar(40)
  amount            Decimal         @db.Decimal(12, 2)
  currency          String          @default("CAD") @db.VarChar(10)
  status            String          @default("pending") @db.VarChar(20)
  provider          String          @default("fake") @db.VarChar(40)
  providerReference String?         @map("provider_reference") @db.VarChar(120)
  paidAt            DateTime?       @map("paid_at")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  enrollment        Enrollment?     @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  enrollmentQuote   EnrollmentQuote? @relation(fields: [enrollmentQuoteId], references: [id], onDelete: SetNull)
  invoice           Invoice?        @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  order             Order?          @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([enrollmentId, status, createdAt])
  @@index([enrollmentQuoteId])
  @@index([invoiceId])
  @@index([orderId])
  @@map("payment")
}

model Order {
  id                String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String          @map("user_id") @db.Uuid
  enrollmentId      String?         @map("enrollment_id") @db.Uuid
  enrollmentQuoteId String?         @unique @map("enrollment_quote_id") @db.Uuid
  type              String          @db.VarChar(30)
  status            String          @default("draft") @db.VarChar(30)
  courseAmount      Decimal         @default(0) @map("course_amount") @db.Decimal(12, 2)
  accommodationAmount Decimal       @default(0) @map("accommodation_amount") @db.Decimal(12, 2)
  fees              Decimal         @default(0) @db.Decimal(12, 2)
  discounts         Decimal         @default(0) @db.Decimal(12, 2)
  totalAmount       Decimal         @map("total_amount") @db.Decimal(12, 2)
  downPaymentPercentage Decimal     @default(30) @map("down_payment_percentage") @db.Decimal(5, 2)
  downPaymentAmount Decimal         @default(0) @map("down_payment_amount") @db.Decimal(12, 2)
  remainingAmount   Decimal         @default(0) @map("remaining_amount") @db.Decimal(12, 2)
  commissionPercentage Decimal      @default(0) @map("commission_percentage") @db.Decimal(7, 4)
  commissionAmount  Decimal         @default(0) @map("commission_amount") @db.Decimal(12, 2)
  commissionCourseAmount Decimal    @default(0) @map("commission_course_amount") @db.Decimal(12, 2)
  commissionAccommodationAmount Decimal @default(0) @map("commission_accommodation_amount") @db.Decimal(12, 2)
  currency          String          @default("CAD") @db.VarChar(10)
  paymentStatus     String          @default("pending") @map("payment_status") @db.VarChar(20)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollment        Enrollment?     @relation("EnrollmentOrders", fields: [enrollmentId], references: [id], onDelete: SetNull)
  enrollmentQuote   EnrollmentQuote? @relation(fields: [enrollmentQuoteId], references: [id], onDelete: SetNull)
  items             OrderItem[]
  payments          Payment[]
  linkedFromEnrollment Enrollment[] @relation("EnrollmentAccommodationOrder")

  @@index([userId, status, createdAt])
  @@index([enrollmentId])
  @@index([type])
  @@map("sales_order")
}

model OrderItem {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId         String       @map("order_id") @db.Uuid
  itemType        String       @map("item_type") @db.VarChar(20)
  referenceId     String       @map("reference_id") @db.Uuid
  startDate       DateTime     @map("start_date")
  endDate         DateTime     @map("end_date")
  amount          Decimal      @db.Decimal(12, 2)
  commissionAmount Decimal     @default(0) @map("commission_amount") @db.Decimal(12, 2)
  createdAt       DateTime     @default(now()) @map("created_at")
  courseId        String?      @map("course_id") @db.Uuid
  accommodationId String?      @map("accommodation_id") @db.Uuid
  order           Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  course          Course?      @relation(fields: [courseId], references: [id], onDelete: SetNull)
  accommodation   Accommodation? @relation(fields: [accommodationId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([itemType, referenceId])
  @@index([courseId])
  @@index([accommodationId])
  @@map("sales_order_item")
}

model Invoice {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  number            String        @unique @db.VarChar(40)
  enrollmentId      String?       @map("enrollment_id") @db.Uuid
  enrollmentQuoteId String?       @map("enrollment_quote_id") @db.Uuid
  totalAmount       Decimal       @map("total_amount") @db.Decimal(12, 2)
  dueDate           DateTime      @map("due_date")
  status            String        @default("draft") @db.VarChar(20)
  currency          String        @default("CAD") @db.VarChar(10)
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  enrollment        Enrollment?   @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)
  enrollmentQuote   EnrollmentQuote? @relation(fields: [enrollmentQuoteId], references: [id], onDelete: SetNull)
  items             InvoiceItem[]
  payments          Payment[]

  @@index([enrollmentId, status])
  @@index([enrollmentQuoteId])
  @@index([status, dueDate])
  @@map("invoice")
}

model InvoiceItem {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  invoiceId   String   @map("invoice_id") @db.Uuid
  description String   @db.VarChar(255)
  type        String   @db.VarChar(40)
  amount      Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_item")
}

model Notification {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @db.VarChar(60)
  title     String   @db.VarChar(180)
  message   String
  metadata  Json?
  readAt    DateTime? @map("read_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
  @@map("notification")
}

model EnrollmentQuoteItem {
  id                   String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quoteId              String          @map("quote_id") @db.Uuid
  itemType             String          @map("item_type") @db.VarChar(30)
  referenceId          String          @map("reference_id") @db.Uuid
  startDate            DateTime        @map("start_date")
  endDate              DateTime        @map("end_date")
  amount               Decimal         @db.Decimal(12, 2)
  commissionAmount     Decimal         @default(0) @map("commission_amount") @db.Decimal(12, 2)
  coursePricingId      String?         @map("course_pricing_id") @db.Uuid
  accommodationPricingId String?       @map("accommodation_pricing_id") @db.Uuid
  createdAt            DateTime        @default(now()) @map("created_at")
  quote                EnrollmentQuote @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  coursePricing        CoursePricing?  @relation(fields: [coursePricingId], references: [id], onDelete: SetNull)
  accommodationPricing AccommodationPricing? @relation(fields: [accommodationPricingId], references: [id], onDelete: SetNull)

  @@index([quoteId])
  @@index([itemType, referenceId])
  @@index([coursePricingId])
  @@index([accommodationPricingId])
  @@map("enrollment_quote_item")
}

model EnrollmentStatusHistory {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enrollmentId String     @map("enrollment_id") @db.Uuid
  fromStatus   String?    @map("from_status")
  toStatus     String     @map("to_status")
  reason       String?
  changedById  String?    @map("changed_by_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  changedBy    User?      @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([enrollmentId, createdAt])
  @@map("enrollment_status_history")
}

model EnrollmentAccommodationStatusHistory {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  enrollmentId String     @map("enrollment_id") @db.Uuid
  fromStatus   String?    @map("from_status")
  toStatus     String     @map("to_status")
  reason       String?
  changedById  String?    @map("changed_by_id") @db.Uuid
  createdAt    DateTime   @default(now()) @map("created_at")
  enrollment   Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  changedBy    User?      @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([enrollmentId, createdAt])
  @@map("enrollment_accommodation_status_history")
}

model CommissionConfig {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scopeType   String   @map("scope_type") @db.VarChar(50)
  scopeId     String   @map("scope_id") @db.Uuid
  percentage  Decimal  @default(0) @db.Decimal(7, 4)
  fixedAmount Decimal? @map("fixed_amount") @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([scopeType, scopeId])
  @@index([scopeType])
  @@map("commission_config")
}
